FROM cokoapps/base-dev:20

WORKDIR /home/node/server
ENV npm_config_build_from_source=true \
    npm_config_sharp_libvips=system \
    PKG_CONFIG_PATH=/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/lib/pkgconfig:/usr/share/pkgconfig \
    CPPFLAGS="-I/usr/include/glib-2.0 -I/usr/lib/x86_64-linux-gnu/glib-2.0/include" \
    CFLAGS="-I/usr/include/glib-2.0 -I/usr/lib/x86_64-linux-gnu/glib-2.0/include" \
    CXXFLAGS="-I/usr/include/glib-2.0 -I/usr/lib/x86_64-linux-gnu/glib-2.0/include"

USER root
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential python3 python-is-python3 curl pkg-config meson ninja-build libglib2.0-dev libjpeg-dev libpng-dev libwebp-dev libtiff-dev libexpat1-dev libheif-dev && \
    rm -rf /var/lib/apt/lists/*
ARG VIPS_VERSION=8.16.1
RUN curl -L https://github.com/libvips/libvips/releases/download/v${VIPS_VERSION}/vips-${VIPS_VERSION}.tar.xz -o /tmp/vips.tar.xz && \
    tar -xf /tmp/vips.tar.xz -C /tmp && \
    cd /tmp/vips-${VIPS_VERSION} && \
    meson setup builddir --prefix=/usr/local --libdir=lib --buildtype=release --default-library=shared --wrap-mode=nodownload && \
    ninja -C builddir && ninja -C builddir install && ldconfig && \
    rm -rf /tmp/vips-${VIPS_VERSION} /tmp/vips.tar.xz
RUN npm install -g node-gyp

COPY .yarnrc.yml .
COPY package.json .
COPY yarn.lock .

RUN chown -R node:node .
USER node

RUN yarn install --immutable || (find /tmp -name build.log -print -exec cat {} \; && exit 1)
RUN yarn cache clean && rm -rf ~/.npm

COPY --chown=node:node . .
