FROM cokoapps/base:20

WORKDIR /home/node/ketida

COPY .yarnrc.yml .
COPY package.json .
COPY yarn.lock .

RUN yarn workspaces focus --production && yarn cache clean && rm -rf ~/.npm

COPY app app
COPY static static

ARG server_url
ARG websocket_server_url
ENV SERVER_URL=$server_url
ENV WEBSOCKET_SERVER_URL=$websocket_server_url

ENV NODE_ENV='production'
ENV CLIENT_PAGE_TITLE='Ketty'
ENV CLIENT_FAVICON_PATH='../static/ketida.ico'
ENV CLIENT_LANGUAGE='en-US'

RUN yarn coko-client-build-js

############################################################################

FROM nginx:alpine

COPY ./nginx/default.conf /etc/nginx/conf.d/default.conf
COPY ./env.sh /usr/share/nginx/html

COPY --from=0 /home/node/ketida/_build /usr/share/nginx/html

WORKDIR /usr/share/nginx/html
ENTRYPOINT ["sh", "./env.sh"]
CMD ["nginx", "-g", "daemon off;"]
